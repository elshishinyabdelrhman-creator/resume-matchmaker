# Supabase (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site origin (OAuth + email redirects). Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth → URL configuration: add these to "Redirect URLs"
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback
# Authentication → Providers → Google: enable and paste Web client ID/secret from Google Cloud Console.
# Google Cloud → Credentials → Authorized redirect URIs must include:
#   https://<project-ref>.supabase.co/auth/v1/callback

# AI (server-only)
# Job Match Studio: prefers Claude, otherwise Groq Llama 3.3 70B
ANTHROPIC_API_KEY=
# Optional override, e.g. claude-3-5-sonnet-latest
ANTHROPIC_MODEL=
GROQ_API_KEY=

# Lightweight helpers (upload structuring, legacy tailor flow)
OPENAI_API_KEY=
